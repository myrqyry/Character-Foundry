{
  "name": "the-character-foundry",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run dev",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "dev:api": "python proxy.py",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test -- --run",
    "check:py": "python -m compileall -q api proxy.py",
    "check:foundation": "npm run check:py && npm run build",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "date-fns": "^4.1.0",
    "edge-tts": "^1.0.1",
    "edge-tts-node": "^1.5.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "wavesurfer.js": "^7.12.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
